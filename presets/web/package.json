{
  "name": "@presetter/preset-web",
  "version": "9.0.0",
  "description": "An opinionated presetter preset for a web project",
  "keywords": [
    "presetter",
    "preset"
  ],
  "homepage": "https://github.com/alvis/presetter#readme",
  "bugs": {
    "url": "https://github.com/alvis/presetter/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alvis/presetter.git"
  },
  "license": "MIT",
  "author": "Alvis HT Tang <alvis@hilbert.space>",
  "type": "module",
  "imports": {
    "#*": "./src/*.ts",
    "#tailwind": "./src/tailwind/index.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "run build",
    "lint": "run lint --",
    "prepublishOnly": "run prepare && run prepublishOnly",
    "test": "run test --",
    "test:coverage": "run test:coverage --",
    "test:watch": "run test:watch --",
    "typecheck": "run typecheck --"
  },
  "dependencies": {
    "@presetter/types": "workspace:*"
  },
  "devDependencies": {
    "@presetter/preset-essentials": "workspace:*",
    "presetter": "workspace:*"
  },
  "peerDependencies": {
    "autoprefixer": "catalog:web",
    "eslint-plugin-better-tailwindcss": "catalog:lint",
    "globals": "catalog:web",
    "postcss": "catalog:web",
    "presetter": "workspace:*",
    "tailwindcss": "catalog:web",
    "vitest": "catalog:testing"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./lib/index.js"
    },
    "imports": {
      "#*": "./lib/*.js",
      "#tailwind": "./lib/tailwind/index.js"
    }
  }
}
