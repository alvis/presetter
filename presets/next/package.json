{
  "name": "@presetter/preset-next",
  "version": "9.0.1",
  "description": "An opinionated presetter preset for a Next JS project",
  "keywords": [
    "presetter",
    "preset"
  ],
  "homepage": "https://github.com/alvis/presetter#readme",
  "bugs": {
    "url": "https://github.com/alvis/presetter/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alvis/presetter.git"
  },
  "license": "MIT",
  "author": "Alvis HT Tang <alvis@hilbert.space>",
  "sideEffects": false,
  "type": "module",
  "imports": {
    "#*": "./src/*.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "run build",
    "lint": "run lint --",
    "prepublishOnly": "run prepare && run prepublishOnly",
    "test": "run test --",
    "test:coverage": "run test:coverage --",
    "test:watch": "run test:watch --",
    "typecheck": "run typecheck --"
  },
  "dependencies": {
    "@presetter/preset-esm": "workspace:*",
    "@presetter/preset-react": "workspace:*",
    "@presetter/preset-web": "workspace:*",
    "@presetter/types": "workspace:*",
    "type-fest": "catalog:types"
  },
  "peerDependencies": {
    "@next/eslint-plugin-next": "catalog:nextjs",
    "@presetter/preset-esm": "workspace:*",
    "@presetter/preset-node": "workspace:*",
    "@presetter/preset-react": "workspace:*",
    "@presetter/preset-strict": "workspace:*",
    "@presetter/preset-web": "workspace:*",
    "@tailwindcss/postcss": "catalog:web",
    "next": "catalog:nextjs",
    "postcss-preset-env": "catalog:web",
    "presetter": "workspace:*",
    "sharp": "catalog:image"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./lib/index.js"
    },
    "imports": {
      "#*": "./lib/*.js"
    }
  }
}
