{
  "name": "@presetter/preset-bun",
  "version": "9.0.1",
  "description": "An opinionated presetter preset for Bun projects",
  "keywords": [
    "presetter",
    "preset"
  ],
  "homepage": "https://github.com/alvis/presetter#readme",
  "bugs": {
    "url": "https://github.com/alvis/presetter/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alvis/presetter.git"
  },
  "license": "MIT",
  "author": "Alvis HT Tang <alvis@hilbert.space>",
  "type": "module",
  "imports": {
    "#*": "./src/*.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "run build",
    "lint": "run lint --",
    "prepublishOnly": "run prepare && run prepublishOnly",
    "test": "run test --",
    "test:coverage": "run test:coverage --",
    "test:watch": "run test:watch --",
    "typecheck": "run typecheck --"
  },
  "dependencies": {
    "@presetter/types": "workspace:*"
  },
  "devDependencies": {
    "presetter": "workspace:*"
  },
  "peerDependencies": {
    "@types/bun": "catalog:types",
    "presetter": "workspace:*"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./lib/index.js"
    },
    "imports": {
      "#*": "./lib/*.js"
    }
  }
}
