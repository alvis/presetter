{
  "name": "@presetter/preset-rollup",
  "version": "8.3.0",
  "description": "An opinionated presetter preset for using rollup as a bundler",
  "keywords": [
    "presetter",
    "preset"
  ],
  "homepage": "https://github.com/alvis/presetter#readme",
  "bugs": {
    "url": "https://github.com/alvis/presetter/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alvis/presetter.git"
  },
  "license": "MIT",
  "author": {
    "name": "Alvis HT Tang",
    "email": "alvis@hilbert.space"
  },
  "type": "module",
  "imports": {
    "#*": "./src/*.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "run build",
    "lint": "run lint --",
    "prepublishOnly": "run prepare && run prepublishOnly",
    "test": "run test --",
    "test:coverage": "run test:coverage --",
    "test:watch": "run test:watch --",
    "typecheck": "run typecheck --"
  },
  "dependencies": {
    "@presetter/types": "workspace:*",
    "type-fest": "catalog:types"
  },
  "devDependencies": {
    "presetter": "workspace:*"
  },
  "peerDependencies": {
    "@rollup/plugin-commonjs": "catalog:rollup",
    "@rollup/plugin-graphql": "catalog:rollup",
    "@rollup/plugin-image": "catalog:rollup",
    "@rollup/plugin-json": "catalog:rollup",
    "@rollup/plugin-node-resolve": "catalog:rollup",
    "@rollup/plugin-typescript": "catalog:rollup",
    "@rollup/plugin-yaml": "catalog:rollup",
    "presetter": "workspace:*",
    "rollup": "catalog:rollup",
    "rollup-plugin-import-css": "catalog:rollup",
    "rollup-plugin-tsconfig-paths": "catalog:rollup",
    "rollup-plugin-visualizer": "catalog:rollup"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./lib/index.js"
    },
    "imports": {
      "#*": "./lib/*.js"
    }
  }
}
