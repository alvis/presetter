{
  "ci": {
    "collect": {
      "staticDistDir": "./build",
      "numberOfRuns": 1,
      "url": [
        "http://localhost/",
        "http://localhost/docs/",
        "http://localhost/docs/tutorials/",
        "http://localhost/docs/api/",
        "http://localhost/docs/presets/"
      ]
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.9
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:best-practices": [
          "warn",
          {
            "minScore": 0.9
          }
        ],
        "categories:seo": [
          "error",
          {
            "minScore": 0.9
          }
        ]
      }
    }
  }
}