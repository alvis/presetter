{
  "name": "@presetter/monorepo",
  "version": "8.3.0",
  "private": true,
  "description": "Make project configurations clean with presets",
  "keywords": [],
  "homepage": "https://github.com/alvis/presetter#readme",
  "bugs": {
    "url": "https://github.com/alvis/presetter/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alvis/presetter.git"
  },
  "license": "MIT",
  "author": "Alvis HT Tang <alvis@hilbert.space>",
  "type": "module",
  "scripts": {
    "build": "pnpm --recursive run build",
    "e2e": "pnpm --filter @presetter/e2e test",
    "install": "husky",
    "postinstall": "presetter bootstrap --projects . --projects e2e --projects packages/* --projects presets/*",
    "lint": "run-s \"lint:* -- packages/*/src/** packages/*/spec/** presets/*/src/** presets/*/spec/**\"",
    "lint:eslint": "NODE_OPTIONS=--max-old-space-size=8096 eslint --flag v10_config_lookup_from_file --fix --format stylish --no-error-on-unmatched-pattern --no-warn-ignored --cache --cache-strategy content",
    "lint:fixme": "leasot --skip-unsupported --exit-nicely package.json",
    "lint:prettier": "prettier --write --no-error-on-unmatched-pattern",
    "next": "PRERELEASE=next run-s \"release -- {@}\" --",
    "release": "run release --",
    "release:changelog": "IGNORE_PATHS=examples,e2e run --template release:changelog --",
    "stage": "pnpm --recursive exec lint-staged -- --concurrent=false",
    "test": "run test --",
    "test:coverage": "run test:coverage --",
    "test:e2e": "pnpm --filter @presetter/e2e test:e2e",
    "test:watch": "run test:watch --",
    "typecheck": "pnpm --recursive exec tsc --noEmit --skipLibCheck"
  },
  "devDependencies": {
    "@presetter/preset-monorepo": "workspace:*",
    "@presetter/preset-node": "workspace:*",
    "@types/node": "catalog:types",
    "git-cliff": "catalog:build",
    "presetter": "workspace:*",
    "typescript": "catalog:build"
  },
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
